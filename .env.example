# Supabase — Radar de oportunidades (backend Fase 1).
# Copiar a .env.local y cargar las 3 vars (.env* está en .gitignore: NO se commitea).
# Las mismas 3 hay que cargarlas en Vercel (Project Settings → Environment Variables).
# Origen de los valores: Supabase → Project Settings → API.

# Públicas (van al cliente, no son secretas):
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (anon public key)

# Secreta (SOLO server, nunca exponer al cliente):
SUPABASE_SERVICE_ROLE_KEY=eyJ... (service_role key)

# Panel admin (/admin): emails autorizados al magic-link (coma-separados).
# Si no se setea, default = cohen.david@gmail.com
ADMIN_EMAILS=cohen.david@gmail.com

# Sin estas vars el sitio funciona igual con la data estática de fallback
# (app/lib/oportunidades.ts). Con ellas, el radar pasa a servirse desde la DB.
